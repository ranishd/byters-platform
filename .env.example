# ============================================================
# Environment Variables for Byters Lead Finder
# ============================================================
#
# SETUP INSTRUCTIONS:
#   Windows:   copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# Then fill in your actual API keys below.
# NEVER commit your .env file — it is already in .gitignore.
#
# ============================================================


# ── FRONTEND (Vite/React) ────────────────────────────────────
# These are read by src/ code via import.meta.env.VITE_*
# Prefix VITE_ is REQUIRED for Vite to expose them to the browser.

# Supabase — get from: https://supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Apify — get from: https://console.apify.com > Settings > Integrations
VITE_APIFY_API_KEY=apify_api_your_token_here


# ── BACKEND (Node.js engine/) ────────────────────────────────
# These are read by engine/ code via process.env.*
# They do NOT need the VITE_ prefix.

# Groq AI — get from: https://console.groq.com > API Keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase — same project as above, but read by Node.js (no VITE_ prefix)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Apify — same token as above, read by Node.js scraper
APIFY_API_TOKEN=apify_api_your_token_here

# Demo site base URL — the backend serves demos on port 3000
# Change this to your production domain when deploying (e.g. https://your-app.railway.app)
DEMO_BASE_URL=http://localhost:3000
